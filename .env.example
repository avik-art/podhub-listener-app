# ── Supabase ──────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - NEVER expose to frontend, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── NextAuth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://yourdomain.com

# ── Google OAuth (optional - for social login) ────────────────────
# Get from: https://console.developers.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Admin ─────────────────────────────────────────────────────────
# The email address that has admin access
ADMIN_EMAIL=avik@podhealth.club

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://yourdomain.com
